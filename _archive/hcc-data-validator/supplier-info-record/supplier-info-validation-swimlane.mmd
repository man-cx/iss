%%{init: {'theme':'base', 'themeVariables': { 'fontSize':'14px'}}}%%
flowchart TB
    subgraph Stage1[" "]
        direction TB
        S1[<b>STAGE 1: POST-EXTRACTION VALIDATION</b><br/>Validate extracted files]
    end
    
    subgraph Stage2[" "]
        direction TB
        S2[<b>STAGE 2: TEMPLATE VALIDATION</b><br/>Validate transformed template]
    end
    
    subgraph Stage3[" "]
        direction TB
        S3[<b>STAGE 3: POST-IMPORT VALIDATION</b><br/>Validate imported data]
    end
    
    subgraph Stage4[" "]
        direction TB
        S4[<b>STAGE 4: RECONCILIATION</b><br/>Source vs Target comparison]
    end

    subgraph ECC["🏢 ECC EXTRACTION TEAM"]
        direction LR
        E1[Extract EINA<br/>EINE, A018]
        E2[Extract Vendor<br/>& Material Master]
        E3[Export to<br/>Excel/CSV]
        E4[Fix data issues<br/>Re-extract if needed]
    end

    subgraph VAL["👥 DATA VALIDATION TEAM"]
        direction LR
        V1[Receive files]
        V2[Run 9 validations<br/>1.1-1.9]
        V3[Generate issue<br/>reports]
        V4[Transform to<br/>PC template]
        V5[Run template<br/>validations 2.1-2.8]
        V6[Upload to<br/>test system]
        V7[Monitor<br/>import]
        V8[Run post-import<br/>validations 3.1-3.8]
        V9[Run reconciliation<br/>4.1-4.5]
        V10[Create final<br/>reports]
    end

    subgraph BUS["💼 BUSINESS/PURCHASING TEAM"]
        direction LR
        B1[Review<br/>exceptions]
        B2[Approve zero<br/>prices, duplicates]
        B3[Verify critical<br/>info records]
        B4[UAT testing]
        B5[Final<br/>sign-off]
    end

    subgraph PC["☁️ PUBLIC CLOUD TEAM"]
        direction LR
        P1[Configure<br/>vendors/materials]
        P2[Configure purch<br/>groups, tax codes]
        P3[Prepare import<br/>template format]
        P4[Review import<br/>logs & errors]
    end

    subgraph SYS["🖥️ PUBLIC CLOUD SYSTEM"]
        direction LR
        Y1[Receive<br/>template file]
        Y2[Execute<br/>data import]
        Y3[Generate<br/>import log]
        Y4[Store in<br/>I_PurchasingInfoRecord]
    end

    %% Stage 1 Flow
    E1 --> E2 --> E3 --> V1
    V1 --> V2
    
    V2 -->|Issues found| V3
    V3 -->|Critical errors| E4
    E4 --> E3
    
    V3 -->|Non-critical| B1
    B1 --> B2
    B2 -->|Approved| V4
    B2 -->|Rejected| E4
    
    V2 -->|No issues| V4
    
    %% Stage 2 Flow
    V4 --> V5
    V5 -->|Issues| V4
    V5 -->|Valid| P1
    P1 --> P2
    P2 --> P3
    P3 -->|Ready| V6
    
    %% Stage 3 Flow
    V6 --> Y1
    Y1 --> Y2
    Y2 --> Y3
    Y3 --> V7
    Y2 --> Y4
    V7 --> V8
    
    V8 -->|Errors| P4
    P4 -->|Fix & retry| V4
    V8 -->|Success| V9
    
    %% Stage 4 Flow
    V9 --> B3
    B3 --> B4
    B4 -->|Failed| V4
    B4 -->|Passed| B5
    B5 --> V10
    
    V10 --> END[✅ Migration<br/>Complete]
    
    S1 -.-> Stage1
    S2 -.-> Stage2
    S3 -.-> Stage3
    S4 -.-> Stage4
    
    style Stage1 fill:#e3f2fd,stroke:#1976d2,stroke-width:3px
    style Stage2 fill:#fff3e0,stroke:#f57c00,stroke-width:3px
    style Stage3 fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px
    style Stage4 fill:#e8f5e9,stroke:#388e3c,stroke-width:3px
    
    style ECC fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    style VAL fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style BUS fill:#c8e6c9,stroke:#43a047,stroke-width:2px
    style PC fill:#e1bee7,stroke:#8e24aa,stroke-width:2px
    style SYS fill:#b2dfdb,stroke:#00897b,stroke-width:2px
    
    style END fill:#90EE90,stroke:#2e7d32,stroke-width:3px
    
    style V2 fill:#ffeb3b
    style V5 fill:#ffeb3b
    style V8 fill:#ffeb3b
    style V9 fill:#ffeb3b
    
    style B2 fill:#ff9800
    style B4 fill:#ff9800
    style B5 fill:#4caf50

