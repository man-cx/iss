    style V19 fill:#bbdefb
    
    style V21 fill:#ffe0b2
    style V22 fill:#ffe0b2
    style V23 fill:#ffe0b2
    style V24 fill:#ffe0b2
    style V25 fill:#ffe0b2
    
    style V31 fill:#e1bee7
    style V32 fill:#e1bee7
    
    style V41 fill:#c8e6c9
    style V42 fill:#c8e6c9
    
    style BUS_REV1 fill:#fff59d
    style BUS_REV2 fill:#fff59d
