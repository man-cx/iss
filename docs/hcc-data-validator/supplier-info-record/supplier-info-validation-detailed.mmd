    style STAGE2 fill:#fff3e0,stroke:#f57c00,stroke-width:3px
    style STAGE3 fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px
    style STAGE4 fill:#e8f5e9,stroke:#388e3c,stroke-width:3px
    
    style FAIL1 fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    style FAIL2 fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    
    style V11 fill:#bbdefb
    style V12 fill:#bbdefb
